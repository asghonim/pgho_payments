default_version = '0.0.1'
comment = 'Ledger-first payments: double-entry ledger, wallets, catalog, orders, subscriptions'
relocatable = false
# The script bakes @extschema@ into every function's SET search_path and into
# COMMENT ON statements, substituted once at install time. If this extension were
# relocated via ALTER EXTENSION ... SET SCHEMA, those pinned search_path values would still
# point at the old schema name and functions would stop finding their own tables. Marking
# the extension non-relocatable makes Postgres reject that command outright.
